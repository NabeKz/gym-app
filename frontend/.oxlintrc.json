{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "react", "react-hooks"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "react/react-in-jsx-scope": "off"
  },
  "settings": {
    "react": {
      "version": "19"
    }
  },
  "env": {
    "builtin": true,
    "browser": true
  },
  "ignorePatterns": ["dist", "styled-system", "src/routeTree.gen.ts"]
}
